{
  "folders": [
    { "path": "." }
  ],
  "launch": {
    "configurations": [
        {
            "name": "Attach to My Service",
            "type": "debugpy",
            "request": "attach",
            "justMyCode": false,
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/app",
                    "remoteRoot": "/code/app"
                }
            ],
            "port": 5678,
            "host": "localhost"
        },
        {
            "name": "Run server",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8181"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "stage: register",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app/register.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--slug", "marine_monitor",
                "--service-url", "https://marinemonitor-actions-runner-194556768605.us-central1.run.app"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "envFile": "${workspaceFolder}/local/.env.stage"
        },
        {
            "name": "prod: register",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app/register.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--slug", "marine_monitor",
                "--service-url", "https://marinemonitor-actions-runner-426960321326.us-central1.run.app"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "envFile": "${workspaceFolder}/local/.env.production"
        }

    ]
  }
}
